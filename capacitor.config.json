{
  "appId": "com.linkwords.app",
  "appName": "LinkWords",
  "webDir": ".",
  "server": {
    "androidScheme": "https"
  },
  "plugins": {
    "SplashScreen": {
      "launchAutoHide": true,
      "launchShowDuration": 0,
      "backgroundColor": "#0f0e17",
      "showSpinner": false
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#0f0e17"
    },
    "FirebaseAuthentication": {
      "skipNativeAuth": false,
      "providers": ["google.com", "apple.com", "facebook.com"]
    },
    "AdMob": {
      "appId": {
        "ios": "ca-app-pub-XXXXXXXX~XXXXXXXX",
        "android": "ca-app-pub-XXXXXXXX~XXXXXXXX"
      }
    }
  },
  "ios": {
    "contentInset": "automatic",
    "scheme": "LinkWords"
  },
  "android": {
    "buildOptions": {
      "signingType": "apksigner"
    }
  }
}
